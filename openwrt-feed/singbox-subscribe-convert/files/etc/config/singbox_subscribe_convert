config global 'main'
	option enabled '0'
	option boot_delay '300'
	option port '9716'
	option password 'change_me'
	option subscription_url ''
	option subscription_timeout '30'
	option refresh_interval '2'
	option default_template 'openwrt'
	option cache_dir '/var/lib/singbox-subscribe-convert/cache'
	option log_file '/var/log/singbox-subscribe-convert/server.log'
	option output_config '/etc/momo/profiles/config.json'
	option template_base_url 'http://127.0.0.1/singbox-subscribe-convert/templates'

config template 'openwrt'
	option enabled '1'
	option name 'OpenWrt 1.12 E8450'
	option file 'openwrt-1.12-e8450.json'
	option no_node '➜ Direct'
