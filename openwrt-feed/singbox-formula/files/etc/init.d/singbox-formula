#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

NAME='singbox-formula'
PROG='/usr/bin/sb-sub-c'
CONFIG='singbox_formula'
GEN='/usr/share/singbox-formula/generate-config.sh'
DELAY_HELPER='/usr/share/singbox-formula/run-delayed.sh'
CONF='/etc/singbox-formula/config.yaml'
WORKDIR='/etc/singbox-formula'

start_service() {
	. /lib/functions.sh
	config_load "$CONFIG"

	local mode enabled delay digest tz
	mode="${1:-reconcile}"
	config_get_bool enabled main enabled 0

	case "$mode" in
		boot)
			[ "$enabled" = "1" ] || return 0
			;;
		manual)
			;;
		reconcile)
			;;
		*)
			echo "invalid service start mode: $mode" >&2
			return 2
			;;
	esac

	mkdir -p /var/lib/singbox-formula/cache /var/log/singbox-formula "$WORKDIR"
	"$GEN" >/dev/null || return 1

	# Reconcile always regenerates the canonical file. Publishing no instance
	# then removes main without depending on converter executable availability.
	if [ "$mode" = "reconcile" ] && [ "$enabled" != "1" ]; then
		return 0
	fi

	[ -x "$PROG" ] || {
		echo "$PROG not found or not executable" >&2
		return 1
	}
	if [ "$mode" = "boot" ]; then
		[ -x "$DELAY_HELPER" ] || {
			echo "$DELAY_HELPER not found or not executable" >&2
			return 1
		}
		config_get delay main boot_delay 90
	fi

	digest="$(sha256sum "$CONF" 2>/dev/null)" || {
		echo "failed to hash generated config: $CONF" >&2
		return 1
	}
	digest=${digest%% *}
	case "$digest" in
		????????????????????????????????????????????????????????????????) ;;
		*)
			echo "invalid generated config digest" >&2
			return 1
			;;
	esac
	case "$digest" in
		*[!0-9a-f]*)
			echo "invalid generated config digest" >&2
			return 1
			;;
	esac

	# Drop the cached converter version so the status page re-detects it (e.g.
	# after the sb-sub-c binary was replaced for another architecture).
	rm -f /var/lib/singbox-formula/converter.version 2>/dev/null
	tz="$(uci -q get system.@system[0].timezone 2>/dev/null)"

	procd_open_instance main
	if [ "$mode" = "boot" ]; then
		procd_set_param command "$DELAY_HELPER" "$delay" "$PROG" run -c "$CONF" -d "$WORKDIR"
	else
		procd_set_param command "$PROG" run -c "$CONF" -d "$WORKDIR"
	fi
	if [ -n "$tz" ]; then
		procd_set_param env "TZ=$tz" "CONFIG_DIGEST=$digest"
	else
		procd_set_param env "CONFIG_DIGEST=$digest"
	fi
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 30 5 5
	procd_set_param term_timeout 5
	procd_close_instance
}

boot() {
	start boot
}

reload_service() {
	# rc.common publishes the newly generated, digest-keyed instance atomically.
	# When disabled, start_service opens no instance and procd removes main.
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
