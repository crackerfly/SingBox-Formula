#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

NAME='singbox-formula'
PROG='/usr/bin/sb-sub-c'
CONFIG='singbox_formula'
GEN='/usr/share/singbox-formula/generate-config.sh'
CONF='/etc/singbox-formula/config.yaml'
WORKDIR='/etc/singbox-formula'

start_service() {
	. /lib/functions.sh
	config_load "$CONFIG"
	local enabled
	config_get_bool enabled main enabled 0
	[ "$enabled" = "1" ] || {
		echo "$NAME disabled in /etc/config/$CONFIG"
		return 1
	}
	[ -x "$PROG" ] || {
		echo "$PROG not found or not executable"
		return 1
	}
	"$GEN" >/dev/null || return 1
	mkdir -p /var/lib/singbox-formula/cache /var/log/singbox-formula "$WORKDIR"
	procd_open_instance
	procd_set_param command "$PROG" run -c "$CONF" -d "$WORKDIR"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_close_instance
}

boot() {
	. /lib/functions.sh
	config_load "$CONFIG"
	local enabled delay
	config_get_bool enabled main enabled 0
	[ "$enabled" = "1" ] || return 0
	config_get delay main boot_delay 300
	(
		sleep "$delay"
		/etc/init.d/$NAME start
	) &
}

reload_service() {
	"$GEN" >/dev/null || return 1
	/etc/init.d/$NAME restart
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
