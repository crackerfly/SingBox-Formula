#!/bin/sh

. /lib/functions.sh
CONFIG='singbox_formula'
TPL_DIR='/www/singbox-formula/templates'
GEN='/usr/share/singbox-formula/generate-config.sh'
UPDATE='/usr/share/singbox-formula/update.sh'
VALIDATE='/usr/share/singbox-formula/validate-template.sh'
INIT='/etc/init.d/singbox-formula'

json_string() {
	# Emit a JSON-safe string body. Escapes backslash, double quote, newline and
	# ALL control characters (0x00-0x1F), including TAB, so tab-indented template
	# files and log lines never produce invalid JSON that ubus would reject.
	LC_ALL=C awk '
	BEGIN{ ORS=""; for(i=0;i<256;i++) ord[sprintf("%c",i)]=i }
	{
		if(NR>1) printf "\\n"
		n=length($0)
		for(i=1;i<=n;i++){
			c=substr($0,i,1); o=ord[c]
			if(c=="\\") printf "\\\\"
			else if(c=="\"") printf "\\\""
			else if(o<32){
				if(o==8) printf "\\b"
				else if(o==9) printf "\\t"
				else if(o==12) printf "\\f"
				else if(o==13) printf "\\r"
				else printf "\\u%04x", o
			}
			else printf "%s", c
		}
	}'
}

json_arg() {
	local key="$1" input="$2"
	printf '%s' "$input" | jsonfilter -e "@.$key" 2>/dev/null
}

sanitize_id() {
	printf '%s' "$1" | tr -cd 'A-Za-z0-9_-' | sed 's/-/_/g'
}

sanitize_file() {
	local f
	[ -n "$1" ] || return 0
	f=$(basename "$1" | tr -cd 'A-Za-z0-9._-')
	[ -n "$f" ] || return 0
	case "$f" in
		*.json) ;;
		*) f="$f.json" ;;
	esac
	printf '%s' "$f"
}

urlencode() {
	# RFC 3986 percent-encoder, byte-accurate (UTF-8 safe). Non-ASCII passwords
	# or template names are encoded per-byte, which is what the converter expects.
	printf '%s' "$1" | LC_ALL=C awk '
	BEGIN{ ORS=""; for(i=0;i<256;i++) ord[sprintf("%c",i)]=i }
	{
		n=length($0)
		for(i=1;i<=n;i++){
			c=substr($0,i,1)
			if(c ~ /[A-Za-z0-9._~-]/) printf "%s", c
			else printf "%%%02X", ord[c]
		}
	}'
}

STATE_DIR='/tmp/singbox-formula'
ACTION_STATE="$STATE_DIR/action.state"
ACTION_PID="$STATE_DIR/action.pid"

_get_port() {
	local p
	p=$(uci -q get $CONFIG.main.port)
	case "$p" in ''|*[!0-9]*) p=9716 ;; esac
	printf '%s' "$p"
}

_health_ok() {
	curl -fsS --connect-timeout 1 --max-time 2 "http://127.0.0.1:${1}/health" >/dev/null 2>&1
}

_wait_health() {
	# _wait_health <port> [max_seconds] - wait until /health answers
	local port="$1" max="${2:-6}" n=0
	while [ "$n" -lt "$max" ]; do
		_health_ok "$port" && return 0
		sleep 1
		n=$((n + 1))
	done
	_health_ok "$port"
}

_conv_pids() {
	pgrep -f '/usr/bin/sb-sub-c' 2>/dev/null
}

_wait_gone() {
	# _wait_gone [max_seconds] - wait until the converter process has exited
	local max="${1:-4}" n=0
	while [ "$n" -lt "$max" ]; do
		[ -z "$(_conv_pids)" ] && return 0
		sleep 1
		n=$((n + 1))
	done
	[ -z "$(_conv_pids)" ]
}

_spawn_update() {
	# _spawn_update <ui_action_name> <update.sh subcommand>
	# Subscription operations can outlive LuCI's ~20s ubus timeout when the
	# provider is slow, so they run detached in the background and this call
	# returns "queued" immediately. update.sh writes its own log lines (the page
	# shows and auto-refreshes them); completion is signalled via $ACTION_STATE,
	# which the status method reports and the frontend polls until done.
	local act="$1" sub="$2" opid rc
	mkdir -p "$STATE_DIR"
	opid=$(cat "$ACTION_PID" 2>/dev/null)
	if [ -n "$opid" ] && kill -0 "$opid" 2>/dev/null; then
		echo "another operation is already running"
		return 1
	fi
	printf '%s running 0 %s\n' "$act" "$(date +%s)" > "$ACTION_STATE"
	# The whole block's stdio must be detached: rpcd (and any $(...) caller)
	# waits for EOF on the plugin's stdout pipe, and a backgrounded child that
	# inherits that pipe keeps it open — turning this back into a synchronous
	# call and resurrecting the ubus timeout. update.sh writes its own log.
	(
		"$UPDATE" "$sub"
		rc=$?
		printf '%s done %s %s\n' "$act" "$rc" "$(date +%s)" > "$ACTION_STATE"
		rm -f "$ACTION_PID"
	) </dev/null >/dev/null 2>/dev/null &
	printf '%s' "$!" > "$ACTION_PID"
	echo "queued"
}

action_cmd() {
	local name="$1" port
	port=$(_get_port)
	case "$name" in
		start)
			"$INIT" start || { echo "start failed - see logread"; return 1; }
			if _wait_health "$port" 6; then
				echo "Converter started and healthy on port $port."
			else
				echo "Converter started, but the health endpoint is not answering yet - check the update log / logread."
			fi
			;;
		stop)
			# procd prints a harmless "service delete ... Not found" when the
			# service is not running; silence it so stop-from-stopped looks clean.
			"$INIT" stop >/dev/null 2>&1
			if _wait_gone 4; then
				echo "Converter stopped."
			else
				echo "Stop requested; the converter process is still terminating."
			fi
			;;
		restart)
			# Stop quietly, wait until the old process has actually exited so the
			# new one can rebind the port immediately (otherwise the fresh instance
			# fails to bind and only comes up after procd's respawn delay, which
			# makes a restart look ineffective), then start and wait for health.
			"$INIT" stop >/dev/null 2>&1
			_wait_gone 4
			"$INIT" start || { echo "restart failed at start - see logread"; return 1; }
			if _wait_health "$port" 6; then
				echo "Converter restarted and healthy on port $port."
			else
				echo "Converter restarted, but the health endpoint is not answering yet - check the update log / logread."
			fi
			;;
		enable)
			# Master switch on: set the autostart flag and bring the service up.
			uci set $CONFIG.main.enabled='1'; uci commit $CONFIG
			"$INIT" enable >/dev/null 2>&1 || true
			action_cmd start
			;;
		disable)
			# Master switch off: clear the autostart flag and stop the service.
			uci set $CONFIG.main.enabled='0'; uci commit $CONFIG
			action_cmd stop
			;;
		generate) "$GEN" ;;
		refresh) _spawn_update refresh refresh ;;
		check) _spawn_update check check ;;
		update|apply) _spawn_update update apply ;;
		log) tail -n 120 /var/log/singbox-formula/update.log 2>/dev/null || true ;;
		*) echo "unknown action: $name" >&2; return 2 ;;
	esac
}

_converter_version() {
	# Report the bundled sb-sub-c version for the status page. Detected once from
	# the binary and cached to a file (cleared on service start), so the polled
	# status call does not exec the binary every time. Falls back to the bundled
	# version if the binary does not print a recognizable version string.
	local f='/var/lib/singbox-formula/converter.version' bin='/usr/bin/sb-sub-c' v=''
	if [ -s "$f" ]; then
		v="$(cat "$f" 2>/dev/null)"
	else
		[ -x "$bin" ] && v="$(timeout 3 "$bin" --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+([.][0-9]+)?' | head -n1)"
		[ -n "$v" ] || v='0.7.2'
		mkdir -p /var/lib/singbox-formula 2>/dev/null
		printf '%s' "$v" > "$f" 2>/dev/null
	fi
	printf '%s' "$v"
}

status_call() {
	config_load "$CONFIG"
	local enabled port password sub_url def output running health update_log pass_q template_q converted_url conv_ver healthy a_name a_state a_code opid cfg_mtime
	config_get_bool enabled main enabled 0
	config_get port main port 9716
	# port is emitted as an unquoted JSON number; coerce empty/non-numeric to the
	# default so the status response is never malformed JSON.
	case "$port" in ''|*[!0-9]*) port=9716 ;; esac
	config_get password main password '890716'
	config_get sub_url main subscription_url ''
	config_get def main default_template momo_template
	config_get output main output_config '/etc/momo/profiles/config.json'
	if "$INIT" running >/dev/null 2>&1; then running=1; else running=0; fi
	pass_q=$(urlencode "$password")
	template_q=$(urlencode "$def")
	converted_url="http://127.0.0.1:${port}/?password=${pass_q}&template=${template_q}"
	if health=$(curl -fsS --connect-timeout 2 --max-time 5 "http://127.0.0.1:$port/health" 2>/dev/null); then
		healthy=true
	else
		healthy=false
		health=''
	fi
	# Background operation state written by _spawn_update: "<name> <state> <code> <ts>".
	a_name=''; a_state='idle'; a_code=0
	if [ -f "$ACTION_STATE" ]; then
		read -r a_name a_state a_code _ < "$ACTION_STATE" 2>/dev/null
		case "$a_code" in ''|*[!0-9]*) a_code=0 ;; esac
		if [ "$a_state" = "running" ]; then
			opid=$(cat "$ACTION_PID" 2>/dev/null)
			[ -n "$opid" ] && kill -0 "$opid" 2>/dev/null || a_state='stale'
		fi
	fi
	# Config file mtime lets the frontend detect when an apply actually committed.
	cfg_mtime=$(date -r /etc/config/singbox_formula +%s 2>/dev/null)
	case "$cfg_mtime" in ''|*[!0-9]*) cfg_mtime=0 ;; esac
	update_log=$(tail -n 40 /var/log/singbox-formula/update.log 2>/dev/null | json_string)
	conv_ver=$(_converter_version)
	printf '{"enabled":%s,"running":%s,"healthy":%s,"port":%s,"subscription_set":%s,"default_template":"%s","output_config":"%s","converted_url":"%s","converter_version":"%s","action":"%s","action_state":"%s","action_code":%s,"config_mtime":%s,"health":"%s","update_log":"%s"}\n' \
		"$enabled" "$running" "$healthy" "$port" "$([ -n "$sub_url" ] && echo true || echo false)" \
		"$(printf '%s' "$def" | json_string)" \
		"$(printf '%s' "$output" | json_string)" \
		"$(printf '%s' "$converted_url" | json_string)" \
		"$(printf '%s' "$conv_ver" | json_string)" \
		"$(printf '%s' "$a_name" | json_string)" \
		"$a_state" \
		"$a_code" \
		"$cfg_mtime" \
		"$(printf '%s' "$health" | json_string)" \
		"$update_log"
}

list_templates_call() {
	mkdir -p "$TPL_DIR"
	config_load "$CONFIG"
	local first=1
	printf '{"templates":['
	_list_one() {
		local sid="$1" enabled name file no_node size mtime
		config_get_bool enabled "$sid" enabled 1
		config_get name "$sid" name "$sid"
		config_get file "$sid" file "$sid.json"
		config_get no_node "$sid" no_node '➜ Direct'
		[ -f "$TPL_DIR/$file" ] && size=$(wc -c < "$TPL_DIR/$file") || size=0
		[ -f "$TPL_DIR/$file" ] && mtime=$(date -r "$TPL_DIR/$file" '+%Y-%m-%d %H:%M:%S' 2>/dev/null) || mtime=''
		[ "$first" = 1 ] || printf ','
		first=0
		printf '{"id":"%s","enabled":%s,"name":"%s","file":"%s","no_node":"%s","size":%s,"mtime":"%s"}' \
			"$sid" "$enabled" \
			"$(printf '%s' "$name" | json_string)" \
			"$(printf '%s' "$file" | json_string)" \
			"$(printf '%s' "$no_node" | json_string)" \
			"$size" "$(printf '%s' "$mtime" | json_string)"
	}
	config_foreach _list_one template
	printf ']}\n'
}

read_template_call() {
	local input id file content
	input=$(cat)
	id=$(sanitize_id "$(json_arg id "$input")")
	file=$(json_arg file "$input")
	config_load "$CONFIG"
	if [ -n "$id" ]; then config_get file "$id" file "$id.json"; fi
	file=$(sanitize_file "$file")
	[ -f "$TPL_DIR/$file" ] || { printf '{"error":"not found"}\n'; return 1; }
	content=$(cat "$TPL_DIR/$file" | json_string)
	printf '{"file":"%s","content":"%s"}\n' "$(printf '%s' "$file" | json_string)" "$content"
}

write_template_call() {
	local input id name file no_node enabled content tmp
	input=$(cat)
	id=$(sanitize_id "$(json_arg id "$input")")
	name=$(json_arg name "$input")
	file=$(sanitize_file "$(json_arg file "$input")")
	no_node=$(json_arg no_node "$input")
	enabled=$(json_arg enabled "$input")
	content=$(json_arg content "$input")
	[ -n "$id" ] || { printf '{"error":"id required"}\n'; return 1; }
	[ -n "$file" ] || { printf '{"error":"file required"}\n'; return 1; }
	[ -n "$name" ] || name="$id"
	[ -n "$no_node" ] || no_node='➜ Direct'
	case "$enabled" in true|1|yes|on) enabled=1 ;; *) enabled=0 ;; esac
	mkdir -p "$TPL_DIR"
	tmp="$TPL_DIR/$file.$$"
	printf '%s' "$content" > "$tmp" || { printf '{"error":"write failed"}\n'; return 1; }
	"$VALIDATE" "$tmp" >/dev/null 2>&1 || { rm -f "$tmp"; printf '{"error":"template validation failed"}\n'; return 1; }
	mv "$tmp" "$TPL_DIR/$file"
	chmod 0644 "$TPL_DIR/$file"
	uci -q get $CONFIG.$id >/dev/null 2>&1 || uci set $CONFIG.$id='template'
	uci set $CONFIG.$id.enabled="$enabled"
	uci set $CONFIG.$id.name="$name"
	uci set $CONFIG.$id.file="$file"
	uci set $CONFIG.$id.no_node="$no_node"
	uci commit "$CONFIG"
	"$GEN" >/dev/null 2>&1 || true
	if "$INIT" running >/dev/null 2>&1; then "$INIT" restart >/dev/null 2>&1 || true; fi
	printf '{"ok":true,"id":"%s","file":"%s"}\n' "$id" "$(printf '%s' "$file" | json_string)"
}

delete_template_call() {
	local input id file def
	input=$(cat)
	id=$(sanitize_id "$(json_arg id "$input")")
	[ -n "$id" ] || { printf '{"error":"id required"}\n'; return 1; }
	config_load "$CONFIG"
	config_get def main default_template momo_template
	[ "$id" = "$def" ] && { printf '{"error":"cannot delete current default_template"}\n'; return 1; }
	config_get file "$id" file ''
	[ -n "$file" ] && rm -f "$TPL_DIR/$(sanitize_file "$file")"
	uci -q delete $CONFIG.$id
	uci commit "$CONFIG"
	"$GEN" >/dev/null 2>&1 || true
	if "$INIT" running >/dev/null 2>&1; then "$INIT" restart >/dev/null 2>&1 || true; fi
	printf '{"ok":true}\n'
}

case "$1" in
	list)
		cat <<'EOF'
{
  "status": {},
  "action": { "name": "" },
  "list_templates": {},
  "read_template": { "id": "", "file": "" },
  "write_template": { "id": "", "name": "", "file": "", "no_node": "", "enabled": true, "content": "" },
  "delete_template": { "id": "" }
}
EOF
		;;
	call)
		case "$2" in
			status) status_call ;;
			list_templates) list_templates_call ;;
			read_template) read_template_call ;;
			write_template) write_template_call ;;
			delete_template) delete_template_call ;;
			action)
				input=$(cat)
				name=$(json_arg name "$input")
				out=$(action_cmd "$name" 2>&1); rc=$?
				printf '{"code":%s,"output":"%s"}\n' "$rc" "$(printf '%s' "$out" | json_string)"
				;;
			*) printf '{"error":"unknown method"}\n'; exit 1 ;;
		esac
		;;
	*)
		echo "usage: $0 {list|call method}" >&2
		exit 1
		;;
esac
