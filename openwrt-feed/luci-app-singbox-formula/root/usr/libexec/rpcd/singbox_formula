#!/bin/sh

umask 077
FUNCTIONS_SH=${SBF_FUNCTIONS_SH:-/lib/functions.sh}
. "$FUNCTIONS_SH" || exit 1
CONFIG=${SBF_CONFIG_NAME:-singbox_formula}
TPL_DIR=${SBF_TEMPLATE_DIR:-/www/singbox-formula/templates}
GEN=${SBF_GENERATOR:-/usr/share/singbox-formula/generate-config.sh}
UPDATE=${SBF_UPDATER:-/usr/share/singbox-formula/update.sh}
VALIDATE=${SBF_TEMPLATE_VALIDATOR:-/usr/share/singbox-formula/validate-template.sh}
INIT=${SBF_INIT_SCRIPT:-/etc/init.d/singbox-formula}
STATE_DIR=${SBF_STATE_DIR:-/var/run/singbox-formula}
ACTION_LOCK="$STATE_DIR/rpc-action.lock"
ACTION_STATE="$STATE_DIR/action.state"
ACTION_ERR="$STATE_DIR/action.err"
ACTION_TIMEOUT=900

# busybox 的 timeout applet 是可裁剪的, 并非所有固件都编入。缺失时降级为
# 直接执行: 丢掉看门狗, 也好过整个动作以 127 退出而根本不运行。
TIMEOUT_BIN=$(command -v timeout 2>/dev/null) || TIMEOUT_BIN=

_run_with_timeout() {
	local seconds="$1"
	shift
	if [ -n "$TIMEOUT_BIN" ]; then
		"$TIMEOUT_BIN" "$seconds" "$@"
		return $?
	fi
	"$@"
}


json_string() {
	# Emit a JSON-safe string body. Escapes backslash, double quote, newline and
	# ALL control characters (0x00-0x1F), including TAB, so tab-indented template
	# files and log lines never produce invalid JSON that ubus would reject.
	LC_ALL=C awk '
	BEGIN{ ORS=""; for(i=0;i<256;i++) ord[sprintf("%c",i)]=i }
	{
		if(NR>1) printf "\\n"
		n=length($0)
		for(i=1;i<=n;i++){
			c=substr($0,i,1); o=ord[c]
			if(c=="\\") printf "\\\\"
			else if(c=="\"") printf "\\\""
			else if(o<32){
				if(o==8) printf "\\b"
				else if(o==9) printf "\\t"
				else if(o==12) printf "\\f"
				else if(o==13) printf "\\r"
				else printf "\\u%04x", o
			}
			else printf "%s", c
		}
	}'
}

json_arg() {
	local key="$1" input="$2"
	printf '%s' "$input" | jsonfilter -e "@.$key" 2>/dev/null
}

valid_id() {
	case "$1" in ''|*[!A-Za-z0-9_]*) return 1 ;; esac
}

valid_file() {
	case "$1" in
		''|.*|*/*|*'..'*|*[!A-Za-z0-9._-]*|*.json.json) return 1 ;;
		*.json) [ "${#1}" -le 128 ] ;;
		*) return 1 ;;
	esac
}

valid_text() {
	! printf '%s' "$1" | LC_ALL=C grep -q '[[:cntrl:]]'
}

template_reply_error() {
	printf '{"ok":false,"phase":"%s","error":"%s"}\n' \
		"$(printf '%s' "$1" | json_string)" "$(printf '%s' "$2" | json_string)"
}

restore_template_backup() {
	local backup="$1" destination="$2" restore
	restore=$(mktemp "$TPL_DIR/.template.restore.XXXXXX") || return 1
	cp -p "$backup" "$restore" && mv "$restore" "$destination" || {
		rm -f "$restore"
		return 1
	}
}

TEMPLATE_LOCK=
template_lock_acquire() {
	local current owner_pid owner_start extra self_start
	_secure_state_dir || return 1
	TEMPLATE_LOCK="$STATE_DIR/template.lock"
	if mkdir "$TEMPLATE_LOCK" 2>/dev/null; then
		self_start=$(_process_start $$) || { rmdir "$TEMPLATE_LOCK" 2>/dev/null; return 1; }
		case "$self_start" in ''|*[!0-9]*) rmdir "$TEMPLATE_LOCK" 2>/dev/null; return 1 ;; esac
		printf '%s %s\n' "$$" "$self_start" > "$TEMPLATE_LOCK/owner" || { rmdir "$TEMPLATE_LOCK" 2>/dev/null; return 1; }
		chmod 0600 "$TEMPLATE_LOCK/owner" || { rm -f "$TEMPLATE_LOCK/owner"; rmdir "$TEMPLATE_LOCK" 2>/dev/null; return 1; }
		return 0
	fi
	[ -d "$TEMPLATE_LOCK" ] && [ ! -L "$TEMPLATE_LOCK" ] || return 1
	IFS=' ' read -r owner_pid owner_start extra < "$TEMPLATE_LOCK/owner" 2>/dev/null || return 75
	[ -z "$extra" ] || return 75
	case "$owner_pid:$owner_start" in ''|*[!0-9:]*) return 75 ;; esac
	current=$(_process_start "$owner_pid" 2>/dev/null || true)
	[ -z "$current" ] || [ "$current" != "$owner_start" ] || return 75
	rm -f "$TEMPLATE_LOCK/owner" && rmdir "$TEMPLATE_LOCK" || return 75
	template_lock_acquire
}

template_lock_release() {
	[ -n "$TEMPLATE_LOCK" ] || return 0
	rm -f "$TEMPLATE_LOCK/owner" 2>/dev/null
	rmdir "$TEMPLATE_LOCK" 2>/dev/null
	TEMPLATE_LOCK=
}

urlencode() {
	# RFC 3986 percent-encoder, byte-accurate (UTF-8 safe). Non-ASCII passwords
	# or template names are encoded per-byte, which is what the converter expects.
	printf '%s' "$1" | LC_ALL=C awk '
	BEGIN{ ORS=""; for(i=0;i<256;i++) ord[sprintf("%c",i)]=i }
	{
		n=length($0)
		for(i=1;i<=n;i++){
			c=substr($0,i,1)
			if(c ~ /[A-Za-z0-9._~-]/) printf "%s", c
			else printf "%%%02X", ord[c]
		}
	}'
}

_get_port() {
	local p
	p=$(uci -q get $CONFIG.main.port)
	case "$p" in ''|*[!0-9]*) p=9716 ;; esac
	printf '%s' "$p"
}

_health_response() {
	local port="$1" body service version status
	body=$(curl -fsS --connect-timeout 1 --max-time 2 "http://127.0.0.1:${port}/health" 2>/dev/null) || return 1
	service=$(printf '%s' "$body" | jsonfilter -e '@.service' 2>/dev/null) || return 1
	version=$(printf '%s' "$body" | jsonfilter -e '@.version' 2>/dev/null) || return 1
	status=$(printf '%s' "$body" | jsonfilter -e '@.status' 2>/dev/null) || return 1
	[ "$service" = 'singbox-subscribe-convert' ] || return 1
	[ "$status" = 'ok' ] || return 1
	case "$version" in ''|unknown) return 1 ;; esac
	printf '%s' "$body"
}

_health_ok() {
	_health_response "$1" >/dev/null
}

_wait_health() {
	# _wait_health <port> [max_seconds] - wait until /health answers
	local port="$1" max="${2:-6}" n=0
	while [ "$n" -lt "$max" ]; do
		_health_ok "$port" && return 0
		sleep 1
		n=$((n + 1))
	done
	_health_ok "$port"
}

_wait_gone() {
	local max="${1:-4}" n=0
	while [ "$n" -lt "$max" ]; do
		"$INIT" running >/dev/null 2>&1 || return 0
		sleep 1
		n=$((n + 1))
	done
	! "$INIT" running >/dev/null 2>&1
}

_process_start() {
	local pid="$1" line
	if [ -n "${SBF_PROCESS_START_HELPER:-}" ]; then
		"$SBF_PROCESS_START_HELPER" "$pid"
		return
	fi
	[ -r "/proc/$pid/stat" ] || return 1
	IFS= read -r line < "/proc/$pid/stat" || return 1
	printf '%s\n' "$line" | awk '{ sub(/^.*\) /, ""); split($0,f," "); print f[20] }'
}

_secure_state_dir() {
	mkdir -p "$STATE_DIR" || return 1
	[ -d "$STATE_DIR" ] && [ ! -L "$STATE_DIR" ] || return 1
	chmod 0700 "$STATE_DIR"
}

_state_write() {
	local action="$1" state="$2" code="$3" token="$4" tmp
	tmp=$(mktemp "$STATE_DIR/.action.state.XXXXXX") || return 1
	printf '%s %s %s %s %s\n' "$action" "$state" "$code" "$(date +%s)" "$token" > "$tmp" || { rm -f "$tmp"; return 1; }
	chmod 0600 "$tmp" || { rm -f "$tmp"; return 1; }
	mv "$tmp" "$ACTION_STATE"
}

_lock_read() {
	local extra
	LOCK_PID= LOCK_START= LOCK_TOKEN=
	[ -f "$ACTION_LOCK/owner" ] && [ ! -L "$ACTION_LOCK/owner" ] || return 1
	IFS=' ' read -r LOCK_PID LOCK_START LOCK_TOKEN extra < "$ACTION_LOCK/owner" || return 1
	[ -z "$extra" ] || return 1
	case "$LOCK_PID:$LOCK_START:$LOCK_TOKEN" in *[!0-9:A-Za-z._-]*|::*|*::*) return 1 ;; esac
}

_lock_acquire() {
	local current observed token claim parent self_start empty_wait
	_secure_state_dir || return 1
	parent=${ACTION_LOCK%/*}
	token="$$.$(date +%s).$(od -An -N8 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
	self_start=$(_process_start $$) || return 1
	case "$self_start" in ''|*[!0-9]*) return 1 ;; esac
	claim=$(mktemp "$parent/.rpc-owner.XXXXXX") || return 1
	printf '%s %s %s\n' "$$" "$self_start" "$token" > "$claim" || { rm -f "$claim"; return 1; }
	chmod 0600 "$claim" || { rm -f "$claim"; return 1; }
	if mkdir "$ACTION_LOCK" 2>/dev/null; then
		mv "$claim" "$ACTION_LOCK/owner" || { rmdir "$ACTION_LOCK" 2>/dev/null; rm -f "$claim"; return 1; }
		printf '%s' "$token"
		return 0
	fi
	rm -f "$claim"
	[ -d "$ACTION_LOCK" ] && [ ! -L "$ACTION_LOCK" ] || return 1
	if [ ! -e "$ACTION_LOCK/owner" ]; then
		empty_wait=0
		while [ "$empty_wait" -lt 2 ] && [ ! -e "$ACTION_LOCK/owner" ]; do sleep 1; empty_wait=$((empty_wait + 1)); done
		if [ ! -e "$ACTION_LOCK/owner" ]; then
			rmdir "$ACTION_LOCK" 2>/dev/null || return 75
			_lock_acquire
			return
		fi
	fi
	_lock_read || return 75
	current=$(_process_start "$LOCK_PID" 2>/dev/null || true)
	[ -z "$current" ] || [ "$current" != "$LOCK_START" ] || return 75
	observed=$(cat "$ACTION_LOCK/owner" 2>/dev/null) || return 75
	[ "$observed" = "$LOCK_PID $LOCK_START $LOCK_TOKEN" ] || return 75
	if [ -e "$ACTION_LOCK/ready" ]; then
		[ -f "$ACTION_LOCK/ready" ] && [ ! -L "$ACTION_LOCK/ready" ] || return 75
		rm -f "$ACTION_LOCK/ready" || return 75
	fi
	rm -f "$ACTION_LOCK/owner" && rmdir "$ACTION_LOCK" || return 75
	_lock_acquire
}

_lock_release_token() {
	local token="$1"
	_lock_read || return 0
	[ "$LOCK_TOKEN" = "$token" ] || return 0
	rm -f "$ACTION_LOCK/ready" 2>/dev/null
	rm -f "$ACTION_LOCK/owner" 2>/dev/null
	rmdir "$ACTION_LOCK" 2>/dev/null
}

_spawn_update() {
	local act="$1" sub="$2" token rc worker worker_start owner_tmp n
	# 提前拦住 exec 层面的失败, 否则用户只会看到一个不透明的 126/127。
	if [ ! -f "$UPDATE" ]; then
		echo "updater $UPDATE is missing"
		return 1
	fi
	if [ ! -x "$UPDATE" ]; then
		echo "updater $UPDATE is not executable"
		return 1
	fi
	token=$(_lock_acquire) || { echo 'another operation is already running'; return 75; }
	_state_write "$act" running 0 "$token" || { _lock_release_token "$token"; return 1; }
	: > "$ACTION_ERR" 2>/dev/null || true
	(
		n=0
		while [ ! -f "$ACTION_LOCK/ready" ] && [ "$n" -lt 5 ]; do sleep 1; n=$((n + 1)); done
		[ -f "$ACTION_LOCK/ready" ] || exit 1
		_run_with_timeout "$ACTION_TIMEOUT" "$UPDATE" "$sub"
		rc=$?
		_state_write "$act" done "$rc" "$token"
		_lock_release_token "$token"
	# stderr 必须落盘而不是丢弃: updater 之外的失败(exec 错误、缺少 applet)
	# 不会进 update.log, 丢掉之后就完全无从排查。stdout 仍走 /dev/null,
	# 因为 rpcd 要等插件的 stdout 关闭才会返回。
	) </dev/null >/dev/null 2>"$ACTION_ERR" &
	worker=$!
	worker_start=$(_process_start "$worker" 2>/dev/null) || {
		kill "$worker" 2>/dev/null || true
		_lock_release_token "$token"
		return 1
	}
	owner_tmp=$(mktemp "$STATE_DIR/.rpc-worker.XXXXXX") || {
		kill "$worker" 2>/dev/null || true
		_lock_release_token "$token"
		return 1
	}
	printf '%s %s %s\n' "$worker" "$worker_start" "$token" > "$owner_tmp" && chmod 0600 "$owner_tmp" && mv "$owner_tmp" "$ACTION_LOCK/owner" && : > "$ACTION_LOCK/ready" || {
		rm -f "$owner_tmp"
		kill "$worker" 2>/dev/null || true
		_lock_release_token "$token"
		return 1
	}
	echo queued
}

service_action_cmd() {
	local name="$1" port
	port=$(_get_port)
	case "$name" in
		start)
			"$INIT" start manual || { echo "start failed - see logread"; return 1; }
			if _wait_health "$port" 6; then
				echo "Converter started and healthy on port $port."
			else
				echo "Converter started, but the health endpoint is not answering yet - check the update log / logread."
			fi
			;;
		stop)
			# procd prints a harmless "service delete ... Not found" when the
			# service is not running; silence it so stop-from-stopped looks clean.
			"$INIT" stop >/dev/null 2>&1
			if _wait_gone 4; then
				echo "Converter stopped."
			else
				echo "Stop requested; the converter process is still terminating."
			fi
			;;
		restart)
			# Stop quietly, wait until the old process has actually exited so the
			# new one can rebind the port immediately (otherwise the fresh instance
			# fails to bind and only comes up after procd's respawn delay, which
			# makes a restart look ineffective), then start and wait for health.
			"$INIT" stop >/dev/null 2>&1
			_wait_gone 4
			"$INIT" start manual || { echo "restart failed at start - see logread"; return 1; }
			if _wait_health "$port" 6; then
				echo "Converter restarted and healthy on port $port."
			else
				echo "Converter restarted, but the health endpoint is not answering yet - check the update log / logread."
			fi
			;;
		*) echo "unknown service action: $name" >&2; return 2 ;;
	esac
}

_valid_ipv4() {
	local ip="$1" part count=0 IFS
	case "$ip" in ''|*[!0-9.]*|.*|*.|*..*) return 1 ;; esac
	IFS='.'
	for part in $ip; do
		count=$((count + 1))
		[ "${#part}" -le 3 ] || return 1
		[ "$part" -le 255 ] 2>/dev/null || return 1
	done
	[ "$count" = 4 ]
}

# 取本机局域网 IPv4。优先问 ubus 要 lan 接口的实际地址, 因为 DHCP 客户端
# 模式下 UCI 里的 network.lan.ipaddr 可能是空的。
_lan_address() {
	local ip=''
	ip=$(ubus call network.interface.lan status 2>/dev/null \
		| jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null)
	if ! _valid_ipv4 "$ip"; then
		ip=$(uci -q get network.lan.ipaddr 2>/dev/null | awk '{print $1}')
	fi
	_valid_ipv4 "$ip" || return 1
	case "$ip" in 127.*) return 1 ;; esac
	printf '%s' "$ip"
}

_converter_version() {
	# Detect once from the target-built binary and cache only a recognizable
	# version. Never invent a fallback version: unknown identity fails closed.
	local f='/var/lib/singbox-formula/converter.version' bin='/usr/bin/sb-sub-c' v=''
	if [ -s "$f" ]; then
		v="$(cat "$f" 2>/dev/null)"
	fi
	case "$v" in *[!0-9.]*|''|.*|*.) v='' ;; esac
	if [ -z "$v" ]; then
		[ -x "$bin" ] && v="$(_run_with_timeout 3 "$bin" --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+([.][0-9]+)?(-[A-Za-z0-9.]+)?' | head -n1)"
		if [ -n "$v" ]; then
			mkdir -p /var/lib/singbox-formula 2>/dev/null
			printf '%s' "$v" > "$f" 2>/dev/null
		fi
	fi
	printf '%s' "${v:-unknown}"
}

status_call() {
	config_load "$CONFIG"
	local enabled port password sub_url def output running health update_log pass_q template_q converted_url lan_ip lan_url conv_ver healthy a_name a_state a_code a_ts a_token extra config_digest config_error current
	config_get_bool enabled main enabled 0
	config_get port main port 9716
	config_error=''
	case "$port" in
		''|*[!0-9]*) config_error='invalid converter port'; port=0 ;;
		*) [ "$port" -ge 1 ] 2>/dev/null && [ "$port" -le 65535 ] 2>/dev/null || { config_error='invalid converter port'; port=0; } ;;
	esac
	config_get password main password '890716'
	config_get sub_url main subscription_url ''
	config_get def main default_template momo_template
	config_get output main output_config '/etc/momo/profiles/config.json'
	if "$INIT" running >/dev/null 2>&1; then running=1; else running=0; fi
	pass_q=$(urlencode "$password")
	template_q=$(urlencode "$def")
	converted_url="http://127.0.0.1:${port}/?password=${pass_q}&template=${template_q}"
	lan_url=''
	if [ "$port" -gt 0 ] 2>/dev/null; then
		lan_ip=$(_lan_address 2>/dev/null) && \
			lan_url="http://${lan_ip}:${port}/?password=${pass_q}&template=${template_q}"
	fi
	if [ "$port" -gt 0 ] 2>/dev/null && health=$(_health_response "$port"); then
		healthy=true
		conv_ver=$(printf '%s' "$health" | jsonfilter -e '@.version' 2>/dev/null)
	else
		healthy=false
		health=''
		conv_ver=$(_converter_version)
		case "$conv_ver" in ''|unknown) config_error=${config_error:-'converter version unavailable'} ;; esac
	fi
	# Background operation state: "<name> <state> <code> <timestamp> <token>".
	a_name=''; a_state='idle'; a_code=0
	if [ -f "$ACTION_STATE" ]; then
		IFS=' ' read -r a_name a_state a_code a_ts a_token extra < "$ACTION_STATE" 2>/dev/null
		case "$a_name:$a_state:$a_code:$a_ts:$a_token:$extra" in
			refresh:running:*|refresh:done:*|check:running:*|check:done:*|update:running:*|update:done:*)
				case "$a_code:$a_ts:$a_token:$extra" in *[!0-9:A-Za-z._-]*|::*|*::*) a_name=''; a_state='corrupt'; a_code=1 ;; esac
				;;
			*) a_name=''; a_state='corrupt'; a_code=1 ;;
		esac
		if [ "$a_state" = running ]; then
			if _lock_read && [ "$LOCK_TOKEN" = "$a_token" ]; then
				current=$(_process_start "$LOCK_PID" 2>/dev/null || true)
				[ -n "$current" ] && [ "$current" = "$LOCK_START" ] || a_state='stale'
			else
				a_state='stale'
			fi
		fi
	fi
	config_digest=$(sha256sum /etc/singbox-formula/config.yaml 2>/dev/null | awk '{print $1}')
	case "$config_digest" in ''|*[!0-9a-f]*) config_digest=''; config_error=${config_error:-'generated config unavailable'} ;; esac
	update_log=$(tail -n 40 /var/log/singbox-formula/update.log 2>/dev/null | json_string)
	printf '{"enabled":%s,"running":%s,"healthy":%s,"port":%s,"subscription_set":%s,"default_template":"%s","output_config":"%s","converted_url":"%s","lan_url":"%s","converter_version":"%s","action":"%s","action_state":"%s","action_code":%s,"config_digest":"%s","config_error":"%s","health":"%s","update_log":"%s"}\n' \
		"$enabled" "$running" "$healthy" "$port" "$([ -n "$sub_url" ] && echo true || echo false)" \
		"$(printf '%s' "$def" | json_string)" \
		"$(printf '%s' "$output" | json_string)" \
		"$(printf '%s' "$converted_url" | json_string)" \
		"$(printf '%s' "$lan_url" | json_string)" \
		"$(printf '%s' "$conv_ver" | json_string)" \
		"$(printf '%s' "$a_name" | json_string)" \
		"$a_state" \
		"$a_code" \
		"$config_digest" \
		"$(printf '%s' "$config_error" | json_string)" \
		"$(printf '%s' "$health" | json_string)" \
		"$update_log"
}

list_templates_call() {
	mkdir -p "$TPL_DIR"
	config_load "$CONFIG"
	local first=1
	printf '{"templates":['
	_list_one() {
		local sid="$1" enabled name file no_node size mtime
		config_get_bool enabled "$sid" enabled 1
		config_get name "$sid" name "$sid"
		config_get file "$sid" file "$sid.json"
		config_get no_node "$sid" no_node '➜ Direct'
		if valid_file "$file" && [ -f "$TPL_DIR/$file" ] && [ ! -L "$TPL_DIR/$file" ]; then
			size=$(wc -c < "$TPL_DIR/$file")
			mtime=$(date -r "$TPL_DIR/$file" '+%Y-%m-%d %H:%M:%S' 2>/dev/null)
		else
			size=0; mtime=''
		fi
		[ "$first" = 1 ] || printf ','
		first=0
		printf '{"id":"%s","enabled":%s,"name":"%s","file":"%s","no_node":"%s","size":%s,"mtime":"%s"}' \
			"$(printf '%s' "$sid" | json_string)" "$enabled" \
			"$(printf '%s' "$name" | json_string)" \
			"$(printf '%s' "$file" | json_string)" \
			"$(printf '%s' "$no_node" | json_string)" \
			"$size" "$(printf '%s' "$mtime" | json_string)"
	}
	config_foreach _list_one template
	printf ']}\n'
}

read_template_call() {
	local input id file content size
	input=$(cat)
	id=$(json_arg id "$input")
	valid_id "$id" || { template_reply_error validate 'invalid template id'; return 1; }
	config_load "$CONFIG"
	config_get file "$id" file ''
	valid_file "$file" || { template_reply_error lookup 'template metadata is invalid'; return 1; }
	[ -f "$TPL_DIR/$file" ] && [ ! -L "$TPL_DIR/$file" ] || { template_reply_error lookup 'not found'; return 1; }
	size=$(wc -c < "$TPL_DIR/$file" 2>/dev/null)
	[ "$size" -le 1048576 ] 2>/dev/null || { template_reply_error validate 'template exceeds 1 MiB'; return 1; }
	content=$(cat "$TPL_DIR/$file" | json_string)
	printf '{"ok":true,"phase":"complete","id":"%s","file":"%s","content":"%s"}\n' "$id" "$(printf '%s' "$file" | json_string)" "$content"
}

write_template_call() {
	local input id name file no_node enabled content stage backup uci_backup old_file def file_owner message existed=0 file_installed=0 committed=0 backup_restored=0
	input=$(cat)
	id=$(json_arg id "$input")
	name=$(json_arg name "$input")
	file=$(json_arg file "$input")
	no_node=$(json_arg no_node "$input")
	enabled=$(json_arg enabled "$input")
	content=$(json_arg content "$input")
	valid_id "$id" || { template_reply_error validate 'invalid template id'; return 1; }
	valid_file "$file" || { template_reply_error validate 'invalid template file'; return 1; }
	valid_text "$name" && valid_text "$no_node" || { template_reply_error validate 'template metadata contains control characters'; return 1; }
	[ "$(printf '%s' "$content" | wc -c)" -le 1048576 ] 2>/dev/null || { template_reply_error validate 'template exceeds 1 MiB'; return 1; }
	[ -n "$name" ] || name="$id"
	[ -n "$no_node" ] || no_node='➜ Direct'
	case "$enabled" in true|1|yes|on) enabled=1 ;; *) enabled=0 ;; esac
	template_lock_acquire || { template_reply_error lock 'another template operation is running'; return 75; }
	mkdir -p "$TPL_DIR" || { template_lock_release; template_reply_error stage 'cannot create template directory'; return 1; }
	[ -d "$TPL_DIR" ] && [ ! -L "$TPL_DIR" ] || { template_lock_release; template_reply_error validate 'unsafe template directory'; return 1; }
	stage=$(mktemp "$TPL_DIR/.template.new.XXXXXX") || { template_lock_release; template_reply_error stage 'cannot create staging file'; return 1; }
	backup=$(mktemp "$STATE_DIR/.template.backup.XXXXXX") || { rm -f "$stage"; template_lock_release; template_reply_error stage 'cannot create backup'; return 1; }
	uci_backup=$(mktemp "$STATE_DIR/.template.uci.XXXXXX") || { rm -f "$stage" "$backup"; template_lock_release; template_reply_error stage 'cannot snapshot UCI'; return 1; }
	if ! printf '%s' "$content" > "$stage" || ! chmod 0600 "$stage" || ! "$VALIDATE" "$stage" >/dev/null 2>&1; then
		rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error validate 'template validation failed'; return 1
	fi
	config_load "$CONFIG"
	file_owner=''
	_find_file_owner() {
		local candidate="$1" candidate_file
		[ "$candidate" = "$id" ] && return 0
		config_get candidate_file "$candidate" file ''
		[ "$candidate_file" != "$file" ] || file_owner="$candidate"
	}
	config_foreach _find_file_owner template
	[ -z "$file_owner" ] || { rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error validate 'template file is already owned by another id'; return 1; }
	config_get def main default_template momo_template
	[ "$id" = "$def" ] && [ "$enabled" = 0 ] && { rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error validate 'cannot disable current default_template'; return 1; }
	if uci -q get "$CONFIG.$id" >/dev/null 2>&1; then
		existed=1; config_get old_file "$id" file ''
		[ "$old_file" = "$file" ] || { rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error validate 'template id and file are immutable'; return 1; }
	fi
	uci export "$CONFIG" > "$uci_backup" 2>/dev/null || { rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error snapshot 'cannot snapshot UCI'; return 1; }
	if [ -e "$TPL_DIR/$file" ]; then
		[ -f "$TPL_DIR/$file" ] && [ ! -L "$TPL_DIR/$file" ] || { rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error validate 'unsafe template destination'; return 1; }
		cp -p "$TPL_DIR/$file" "$backup" || { rm -f "$stage" "$backup" "$uci_backup"; template_lock_release; template_reply_error snapshot 'cannot back up template'; return 1; }
	else
		rm -f "$backup"; backup=''
	fi
	if mv "$stage" "$TPL_DIR/$file" && chmod 0644 "$TPL_DIR/$file"; then file_installed=1; else stage=''; fi
	if [ "$file_installed" = 1 ]; then
		[ "$existed" = 1 ] || uci set "$CONFIG.$id=template"
		uci set "$CONFIG.$id.enabled=$enabled" && uci set "$CONFIG.$id.name=$name" && uci set "$CONFIG.$id.file=$file" && uci set "$CONFIG.$id.no_node=$no_node" && uci commit "$CONFIG" && "$GEN" >/dev/null 2>&1 && committed=1
	fi
	if [ "$committed" != 1 ]; then
		if [ -n "$backup" ]; then
			restore_template_backup "$backup" "$TPL_DIR/$file" 2>/dev/null && backup_restored=1
		else
			rm -f "$TPL_DIR/$file"
			backup_restored=1
		fi
		uci -q delete "$CONFIG" 2>/dev/null || true
		uci import "$CONFIG" < "$uci_backup" 2>/dev/null && uci commit "$CONFIG" >/dev/null 2>&1 || true
		rm -f "$stage" "$uci_backup"
		if [ "$backup_restored" = 1 ]; then
			rm -f "$backup"; message='template transaction failed and was rolled back'
		else
			message="template transaction failed; recovery backup retained at $backup"
		fi
		template_lock_release; template_reply_error rollback "$message"; return 1
	fi
	rm -f "$stage" "$backup" "$uci_backup"
	template_lock_release
	if "$INIT" running >/dev/null 2>&1; then "$INIT" restart >/dev/null 2>&1 || true; fi
	printf '{"ok":true,"phase":"complete","id":"%s","file":"%s"}\n' "$id" "$(printf '%s' "$file" | json_string)"
}

delete_template_call() {
	local input id file def backup uci_backup backup_restored=0 message
	input=$(cat)
	id=$(json_arg id "$input")
	valid_id "$id" || { template_reply_error validate 'invalid template id'; return 1; }
	template_lock_acquire || { template_reply_error lock 'another template operation is running'; return 75; }
	config_load "$CONFIG"
	config_get def main default_template momo_template
	[ "$id" = "$def" ] && { template_lock_release; template_reply_error validate 'cannot delete current default_template'; return 1; }
	config_get file "$id" file ''
	valid_file "$file" || { template_lock_release; template_reply_error lookup 'template metadata is invalid'; return 1; }
	[ ! -L "$TPL_DIR/$file" ] || { template_lock_release; template_reply_error validate 'unsafe template destination'; return 1; }
	backup=$(mktemp "$STATE_DIR/.template.delete.XXXXXX") || { template_lock_release; template_reply_error snapshot 'cannot create backup'; return 1; }
	uci_backup=$(mktemp "$STATE_DIR/.template.uci.XXXXXX") || { rm -f "$backup"; template_lock_release; template_reply_error snapshot 'cannot snapshot UCI'; return 1; }
	uci export "$CONFIG" > "$uci_backup" 2>/dev/null || { rm -f "$backup" "$uci_backup"; template_lock_release; template_reply_error snapshot 'cannot snapshot UCI'; return 1; }
	[ -f "$TPL_DIR/$file" ] && cp -p "$TPL_DIR/$file" "$backup" || rm -f "$backup"
	if ! uci -q delete "$CONFIG.$id" || ! uci commit "$CONFIG" || ! "$GEN" >/dev/null 2>&1 || ! rm -f "$TPL_DIR/$file"; then
		if [ ! -f "$backup" ]; then backup_restored=1; elif restore_template_backup "$backup" "$TPL_DIR/$file" 2>/dev/null; then backup_restored=1; fi
		uci -q delete "$CONFIG" 2>/dev/null || true
		uci import "$CONFIG" < "$uci_backup" 2>/dev/null && uci commit "$CONFIG" >/dev/null 2>&1 || true
		rm -f "$uci_backup"
		if [ "$backup_restored" = 1 ]; then
			rm -f "$backup"; message='delete transaction failed and was rolled back'
		else
			message="delete transaction failed; recovery backup retained at $backup"
		fi
		template_lock_release; template_reply_error rollback "$message"; return 1
	fi
	rm -f "$backup" "$uci_backup"
	template_lock_release
	if "$INIT" running >/dev/null 2>&1; then "$INIT" restart >/dev/null 2>&1 || true; fi
	printf '{"ok":true,"phase":"complete"}\n'
}

case "$1" in
	list)
		cat <<'EOF'
{
  "status": {},
  "service_action": { "name": "" },
  "generate": {},
  "refresh": {},
  "check": {},
  "update": {},
  "list_templates": {},
  "read_template": { "id": "", "file": "" },
  "write_template": { "id": "", "name": "", "file": "", "no_node": "", "enabled": true, "content": "" },
  "delete_template": { "id": "" }
}
EOF
		;;
	call)
		case "$2" in
			status) status_call ;;
			service_action)
				input=$(cat); name=$(json_arg name "$input")
				out=$(service_action_cmd "$name" 2>&1); rc=$?
				printf '{"code":%s,"output":"%s"}\n' "$rc" "$(printf '%s' "$out" | json_string)"
				;;
			generate)
				out=$("$GEN" 2>&1); rc=$?
				printf '{"code":%s,"output":"%s"}\n' "$rc" "$(printf '%s' "$out" | json_string)"
				;;
			refresh|check|update)
				method="$2"; sub="$method"; [ "$method" = update ] && sub=apply
				out=$(_spawn_update "$method" "$sub" 2>&1); rc=$?
				printf '{"code":%s,"output":"%s"}\n' "$rc" "$(printf '%s' "$out" | json_string)"
				;;
			list_templates) list_templates_call ;;
			read_template) read_template_call ;;
			write_template) write_template_call ;;
			delete_template) delete_template_call ;;
			*) printf '{"error":"unknown method"}\n'; exit 1 ;;
		esac
		;;
	*)
		echo "usage: $0 {list|call method}" >&2
		exit 1
		;;
esac
