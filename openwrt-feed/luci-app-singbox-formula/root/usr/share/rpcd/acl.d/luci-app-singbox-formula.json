{
  "luci-app-singbox-formula": {
    "description": "Grant access to SingBox Formula LuCI app",
    "read": {
      "ubus": {
        "singbox_formula": [
          "status",
          "list_templates",
          "read_template"
        ]
      },
      "uci": [
        "singbox_formula"
      ],
      "file": {
        "/var/log/singbox-formula/*": [
          "read"
        ],
        "/www/singbox-formula/templates/*": [
          "read"
        ]
      }
    },
    "write": {
      "ubus": {
        "singbox_formula": [
          "action",
          "write_template",
          "delete_template"
        ]
      },
      "uci": [
        "singbox_formula"
      ],
      "file": {
        "/www/singbox-formula/templates/*": [
          "write"
        ],
        "/etc/config/singbox_formula": [
          "write"
        ],
        "/etc/singbox-formula/*": [
          "write"
        ]
      }
    }
  }
}
